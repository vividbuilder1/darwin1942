{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src/**/*.jsx", "src/**/*.js"],
  "exclude": ["node_modules", "dist", "**/*.stories.*"]
}
